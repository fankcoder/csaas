DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Leave MYSQL_HOST empty to use local SQLite for development.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=csaas
MYSQL_USER=root
MYSQL_PASSWORD=

# Optional Redis cache.
REDIS_URL=redis://127.0.0.1:6379/0

# Email verification. Console backend prints emails in development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost
EMAIL_VERIFICATION_TTL_SECONDS=600

# Steam OpenID login. STEAM_API_KEY is only used to fetch public Steam profile data after login.
STEAM_API_KEY=
STEAM_OPENID_REALM=http://127.0.0.1:8000
STEAM_OPENID_RETURN_TO=http://127.0.0.1:8000/api/auth/steam/callback/

# Local highest-permission test account.
DEV_ADMIN_USERNAME=devadmin
DEV_ADMIN_EMAIL=devadmin@example.com
DEV_ADMIN_PASSWORD=DevAdmin12345
DEV_ADMIN_STEAM_ID=76561198153187116

# Pricing assumptions.
USD_CNY_RATE=7.25
BUFF_SELL_FEE=0.025
WAXPEER_SELL_FEE=0.07
SHADOWPAY_SELL_FEE=0.05
