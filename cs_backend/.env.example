DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000

# Leave MYSQL_HOST empty to use local SQLite for development.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=csaas
MYSQL_USER=root
MYSQL_PASSWORD=

# Optional Redis cache.
REDIS_URL=redis://127.0.0.1:6379/0

# Pricing assumptions.
USD_CNY_RATE=7.25
BUFF_SELL_FEE=0.025
WAXPEER_SELL_FEE=0.07
SHADOWPAY_SELL_FEE=0.05
